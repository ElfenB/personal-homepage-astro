{
  "name": "benelfen-personal-homepage",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "predev": "npm install",
    "dev": "astro dev",
    "prebuild": "npm ci",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check-types": "tsc --noEmit --pretty",
    "lint": "npm run check-types && eslint .",
    "lint:fix": "eslint --fix .",
    "prettier": "prettier --write --ignore-unknown .",
    "format": "npm run prettier && npm run lint"
  },
  "dependencies": {
    "astro": "^5.18.0"
  },
  "devDependencies": {
    "@boehringer-ingelheim/eslint-config": "^9.4.0",
    "@boehringer-ingelheim/prettier-config": "^2.0.0",
    "eslint": "^10.0.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*": "npm run lint"
  }
}
