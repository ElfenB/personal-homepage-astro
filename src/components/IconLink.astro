---
import type { SvgComponent } from 'astro/types';

interface Props {
  icon: SvgComponent;
  alt: string;
  style?: astroHTML.JSX.CSSProperties;
  href?: string;
}

const { icon: Icon, alt, style, href } = Astro.props;
---

<a
  aria-label={alt}
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  style="color: inherit; text-decoration: none;"
>
  <Icon aria-label={alt} style={{ ...style, width: '15vh', height: '15vh', display: 'block' }} />
</a>
