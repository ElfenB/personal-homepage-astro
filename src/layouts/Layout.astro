---
import '../styles/font.css';
import manropeFontUrl from '../assets/fonts/Manrope-VariableFont_wght.ttf?url';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Personal homepage of Benjamin Elfen - software engineer, open source contributor, and technology enthusiast. Connect on GitHub and LinkedIn."
    />

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preload" href={manropeFontUrl} as="font" type="font/ttf" crossorigin />

    <meta name="generator" content={Astro.generator} />

    <title>benelfen.</title>
  </head>

  <body>
    <main>
      <slot />
    </main>
  </body>
</html>

<style>
  html,
  body,
  main {
    margin: 0;
    width: 100%;
    height: 100%;
    scroll-behavior: smooth;
  }
</style>
